{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "baseUrl": ".",
    "typeRoots": ["./frontend/node_modules/@types"],
    "paths": {
      "*": ["*", "./frontend/node_modules/*"]
    }
  },
  "include": ["stellar.ts"],
  "exclude": ["frontend/node_modules", "node_modules"]
}
